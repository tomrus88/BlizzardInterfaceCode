<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\..\..\..\WoW\Data\Interface\AddOns\Blizzard_SharedXML\UI.xsd">

	<Frame name="TieredEntranceTraitsList" mixin="TieredEntranceTraitsListMixin" inherits="TalentFrameGridTemplate, TalentFrameDisplayOnlyTemplate" virtual="true">
		<KeyValues>
			<KeyValue key="topPadding" value="18" type="number"/>
			<KeyValue key="bottomPadding" value="17" type="number"/>
			<KeyValue key="leftPadding" value="25" type="number"/>
			<KeyValue key="stride" value="4" type="number"/>
			<KeyValue key="paddingX" value="6" type="number"/>
			<KeyValue key="paddingY" value="6" type="number"/>
			<KeyValue key="getTemplateType" value="TieredEntranceTraitsListMixin.GetTemplateForTalentType" type="global"/>
		</KeyValues>
		<Size x="225" y="10"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture parentKey="Background" atlas="themed-scenario-challenge-flyout" setAllPoints="true"/>
			</Layer>
		</Layers>
		<Scripts>
			<OnLoad method="OnLoad"/>
		</Scripts>
	</Frame>

	<Frame name="TieredEntranceTraitSpellTemplate" mixin="TieredEntranceTraitSpellMixin" virtual="true">
		<Size x="40" y="40"/>
		<Anchors>
			<Anchor point="RIGHT" relativePoint="LEFT" x="-10"/>
		</Anchors>
		<Layers>
			<Layer level="ARTWORK">
				<Texture parentKey="Icon">
					<Size x="32" y="32"/>
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<MaskTexture parentKey="IconMask" file="Interface\CharacterFrame\TempPortraitAlphaMask" hWrapMode="CLAMPTOBLACKADDITIVE" vWrapMode="CLAMPTOBLACKADDITIVE">
					<Anchors>
						<Anchor point="TOPLEFT" relativeKey="$parent.Icon"/>
						<Anchor point="BOTTOMRIGHT" relativeKey="$parent.Icon"/>
					</Anchors>
					<MaskedTextures>
						<MaskedTexture childKey="Icon"/>
					</MaskedTextures>
				</MaskTexture>
				<Texture atlas="themed-scenario-challenge-gold-circle" useAtlasSize="true">
					<Anchors>
						<Anchor point="CENTER" relativeKey="$parent.Icon"/>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Scripts>
			<OnEnter method="OnEnter"/>
			<OnLeave function="GameTooltip_Hide"/>
		</Scripts>
	</Frame>

	<Button name="TieredEntranceTraitsContainer" mixin="TieredEntranceTraitsContainerMixin" inherits="AlphaHighlightButtonTemplate" virtual="true">
		<Size x="244" y="31"/>
		<NormalTexture parentKey="NormalTexture" atlas="themed-scenario-challenge-button-up" useAtlasSize="true">
			<Anchors>
				<Anchor point="CENTER"/>
			</Anchors>
		</NormalTexture>
		<PushedTexture parentKey="PushedTexture" atlas="themed-scenario-challenge-button-pressed" useAtlasSize="true">
			<Anchors>
				<Anchor point="CENTER"/>
			</Anchors>
		</PushedTexture>
		<DisabledTexture parentKey="NormalTexture" atlas="themed-scenario-challenge-button-up" useAtlasSize="true" desaturated="true">
			<Anchors>
				<Anchor point="CENTER"/>
			</Anchors>
		</DisabledTexture>
		<HighlightTexture parentKey="HighlightTexture" atlas="themed-scenario-challenge-button-up" useAtlasSize="true" alphaMode="ADD">
			<Anchors>
				<Anchor point="CENTER"/>
			</Anchors>
		</HighlightTexture>
		<ButtonText parentKey="Text" text="Challenges"/>
		<NormalFont style="GameFontHighlight"/>
		<Layers>
			<Layer level="ARTWORK" textureSubLevel="1">
				<Texture parentKey="ThemeOverlay" atlas="themed-scenario-challenge-button-up-add" useAtlasSize="true" alphaMode="ADD">
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</Texture>
				<Texture parentKey="Arrow" hidden="true"/> <!-- configured from UpdateAlignment -->
			</Layer>
		</Layers>
		<Frames>
			<Frame parentKey="List" inherits="TieredEntranceTraitsList" hidden="true"/> <!-- configured from UpdateAlignment -->
		</Frames>
		<Scripts>
			<OnHide method="OnHide"/>
			<OnClick method="OnClick"/>
		</Scripts>
	</Button>
</Ui>
